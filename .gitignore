# Rust
/target/
**/*.rs.bk
*.pdb

# Cargo.lock is tracked (binary workspace).

# Local dev tooling (capture/credential extraction utilities — not part of the receiver)
scripts/

# Cast protocol capture logs + runtime logs
capture_*.jsonl
*.log

# Dev tools under tools/: uv venvs; capture's generated UniFFI bindings + cdylib
# and per-session output (cast/http JSONL, meta.json).
tools/*/.venv/
tools/capture/generated/
tools/capture/captures/

# Certificates / secrets — never commit
*.pem
*.key
certs/

# nextest CI artifact
junit.xml

# Python (the Kodi add-on at kodi/service.vibecast/ and the tools/capture/ dev tool)
__pycache__/
*.py[cod]

# Editor / OS
.idea/
.vscode/
.DS_Store
