capture_*.jsonl
*.log

# Certificates / secrets — never commit
*.pem
*.key
certs/

# nextest CI artifact
junit.xml

# Python (only the Kodi add-on at kodi/service.vibecast/ is Python)
__pycache__/
*.py[cod]

# Editor / OS
.idea/
.vscode/
.DS_Store
