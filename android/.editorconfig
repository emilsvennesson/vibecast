root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{kt,kts}]
indent_size = 4
# Keep in the spirit of the Rust side's max_width = 100, with headroom.
max_line_length = 120
ktlint_standard_no-wildcard-imports = disabled

[*.{gradle.kts,toml,xml}]
indent_size = 4

[*.xml]
indent_size = 4
